# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=invoices_user
DATABASE_PASSWORD=change_me
DATABASE_NAME=invoices_db
DATABASE_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=14d
PASSWORD_RESET_SECRET=your-password-reset-secret-change-in-production
PASSWORD_RESET_EXPIRES_IN=15m
PASSWORD_RESET_EXPOSE_TOKEN=true
APP_BASE_URL=http://localhost:3000

# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE_PREFIX=invoices.service

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Public API / integration configuration
CORS_ORIGIN=*

# External API Configuration (for GST/E-Way Bill compliance)
GST_API_BASE_URL=https://api.gst.gov.in
GST_API_KEY=your-gst-api-key
EWAY_BILL_API_URL=https://ewaybillapi.nic.in
EWAY_BILL_API_KEY=your-eway-bill-api-key
